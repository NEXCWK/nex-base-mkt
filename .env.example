# =============================================
# ANTHROPIC (resumo automático de PDFs)
# =============================================
# Crie uma chave em https://console.anthropic.com (API Keys).
# Necessária para gerar os resumos automáticos dos PDFs enviados.
# Cada PDF é resumido apenas 1 vez e o resultado fica em cache.
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# NEXT AUTH
# =============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here  # Gere com: openssl rand -base64 32

# =============================================
# GOOGLE DRIVE / CALENDAR (Service Account)
# =============================================
# 1. Acesse: https://console.cloud.google.com
# 2. Crie um projeto ou use um existente
# 3. Habilite: Google Drive API e Google Calendar API
# 4. Crie uma Service Account em IAM & Admin > Service Accounts
# 5. Gere uma chave JSON para a Service Account
# 6. Compartilhe a pasta do Drive com o e-mail da Service Account

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_DRIVE_ROOT_FOLDER_ID=1abc123...  # ID da pasta "Marketing, Comunicação e Vendas" no Drive

# Para o Calendar: compartilhe o calendário com o e-mail da Service Account
GOOGLE_CALENDAR_ID=primary  # ou o ID específico do calendário da equipe

# =============================================
# SLACK WEBHOOK
# =============================================
# 1. Acesse: https://api.slack.com/apps
# 2. Crie um app > Incoming Webhooks > Ative
# 3. Adicione o webhook ao canal desejado
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# =============================================
# E-MAIL (NODEMAILER)
# =============================================
# Configuração para envio do report diário
# Exemplo com Gmail: ative 2FA e gere uma App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-app-password  # App Password do Gmail
SMTP_FROM="Nex Coworking <seu-email@gmail.com>"
REPORT_RECIPIENT=felipe@nexcoworking.com.br
